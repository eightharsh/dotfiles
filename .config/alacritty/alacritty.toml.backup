
general.live_config_reload = true


[colors]
draw_bold_text_with_bright_colors = true

[colors.primary]
background = "#2c2b2b"
foreground = "#d5a200"

[colors.normal]
black   = "#000000"
red     = "#c91b00"
green   = "#00c200"
yellow  = "#c7c400"
blue    = "#0225c7"
magenta = "#ca30c7"
cyan    = "#00c5c7"
white   = "#c7c7c7"

[colors.bright]
black   = "#686868"
red     = "#ff6e67"
green   = "#5ffa68"
yellow  = "#fffc67"
blue    = "#6871ff"
magenta = "#ff77ff"
cyan    = "#60fdff"
white   = "#ffffff"

[colors.cursor]
text   = "#2c2b2b"
cursor = "#c7c7c7"

[colors.selection]
background = "#6b5b02"
text       = "#d5a200"





[env]
TERM = "xterm-256color"

[window]
decorations = "buttonless"
dynamic_padding = false
opacity = 0.8
blur = false



[window.padding]
x = 25
y = 20

[font]
size = 18.0

[font.bold]
family = "JetBrainsMono Nerd Font"
style = "Heavy"

[font.bold_italic]
family = "JetBrainsMono Nerd Font"
style = "Heavy Italic"

[font.italic]
family = "JetBrainsMono Nerd Font"
style = "Medium Italic"

[font.normal]
family = "JetBrainsMono Nerd Font"
style = "Medium"

[font.offset]
y = 2


[window.dimensions]
columns = 90
lines   = 25




[selection]
 save_to_clipboard     = true
 semantic_escape_chars = ",│`|:\"' ()[]{}<>"



[scrolling]
    history    = 50000
    multiplier = 4





[cursor]
style = { shape = "Beam", blinking = "On" }
blink_interval = 500


[mouse]
hide_when_typing = true






[[keyboard.bindings]]
key = "N"
mods = "Command"
action = "SpawnNewInstance"

[[keyboard.bindings]]
key = "W"
mods = "Command|Shift"
action = "Quit"

[[keyboard.bindings]]
chars = "\u001Bb"
key = "Left"
mods = "Alt"

[[keyboard.bindings]]
chars = "\u001Bf"
key = "Right"
mods = "Alt"

[[keyboard.bindings]]
chars = "\u0001"
key = "Left"
mods = "Command"

[[keyboard.bindings]]
chars = "\u0005"
key = "Right"
mods = "Command"






