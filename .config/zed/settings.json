{
  "icon_theme": "Zed (Default)",
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    }
  },

  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },

  "restore_on_startup": "last_session",

  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  "theme": "Gruvbox Material",

  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 14,
  "buffer_line_height": {
    "custom": 1.45
  },
  "buffer_font_weight": 500,
  "buffer_font_features": {
    "calt": false
  },

  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 14,

  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always"
  },

  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },

  "project_panel": {
    "entry_spacing": "standard",
    "git_status": true
  },

  "tabs": {
    "file_icons": true,
    "git_status": true
  },

  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false
    }
  },

  "current_line_highlight": "gutter",

  "format_on_save": "off",

  "tab_size": 4,
  "hard_tabs": true,

  "terminal": {
    "dock": "bottom",
    "default_height": 300
  }
}
